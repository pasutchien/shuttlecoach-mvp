# Shuttle Coach — environment flags. Copy to `.env` to override defaults.
# All EXPO_PUBLIC_* vars are inlined into the client bundle at build time.

# Backend selection. Default (unset / anything but "false") uses the mock API.
# Set to "false" to use the real implementation (src/services/real/realApi.ts).
EXPO_PUBLIC_USE_MOCK_API=true

# Seed mode for the mock backend:
#   full  (default) — returning user with profile, 8 analyses and a ledger
#   empty           — brand-new user (demo onboarding + empty states)
EXPO_PUBLIC_SEED=full

# Simulated AI processing duration in seconds (SPEC §9.1 says 30–90s).
# Lower it for a snappier demo, e.g. 10.
EXPO_PUBLIC_MOCK_JOB_SECONDS=30

# Force the analysis job to fail, to demo the error-recovery flow (SPEC §6.3).
# One of: VIDEO_TOO_DARK | PLAYER_NOT_DETECTED | VIDEO_TOO_BLURRY | PROCESSING_TIMEOUT
# Leave unset for the normal happy path.
# EXPO_PUBLIC_FORCE_ANALYSIS_ERROR=VIDEO_TOO_DARK

# Base URL for the real backend (only used when EXPO_PUBLIC_USE_MOCK_API=false).
# EXPO_PUBLIC_API_BASE_URL=https://api.shuttlecoach.app
